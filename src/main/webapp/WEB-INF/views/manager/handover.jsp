<%@ page contentType="text/html;charset=UTF-8" %>
<%@ taglib prefix="c" uri="jakarta.tags.core" %><c:set var="ctx" value="${pageContext.request.contextPath}" /><jsp:include page="../layout/header.jsp" />
<div class="page-header"><div><div class="eyebrow">Vận hành</div><h1>Bàn giao cần tiếp nhận</h1><p>Các nội dung bàn giao chưa có nhân viên ca tiếp theo tiếp nhận.</p></div></div>
<c:if test="${not empty sessionScope.flashError}"><div class="alert alert-error">${sessionScope.flashError}</div><c:remove var="flashError" scope="session" /></c:if><c:if test="${not empty sessionScope.flashOk}"><div class="alert alert-success">${sessionScope.flashOk}</div><c:remove var="flashOk" scope="session" /></c:if>
<c:choose><c:when test="${empty handovers}"><div class="card empty-state"><div class="icon">✓</div><p>Không có bàn giao dự phòng nào.</p></div></c:when><c:otherwise><c:forEach var="h" items="${handovers}"><article class="card" style="margin-bottom:var(--s4)"><h3 style="margin-top:0">${h.createdByName} · ${h.createdDisplay}</h3><c:if test="${not empty h.note}"><p><strong>Ghi chú:</strong> <c:out value="${h.note}" /></p></c:if><span class="badge ${h.overallStatusBadge}">${h.overallStatusLabel}</span><c:if test="${h.canAcknowledge}"><form action="${ctx}/manager/handover" method="post" style="margin:12px 0"><input type="hidden" name="_csrf" value="${sessionScope.csrfToken}"><input type="hidden" name="action" value="acknowledge"><input type="hidden" name="handoverId" value="${h.shiftHandoverId}"><button class="btn btn-primary">Đã nhận bàn giao</button></form></c:if><c:forEach var="t" items="${h.tasks}"><div style="display:flex;gap:10px;align-items:center;justify-content:space-between;border-top:1px solid var(--line);padding:10px 0"><span><c:out value="${t.content}" /></span><c:choose><c:when test="${h.canUpdateTasks}"><form action="${ctx}/manager/handover" method="post"><input type="hidden" name="_csrf" value="${sessionScope.csrfToken}"><input type="hidden" name="action" value="updateTask"><input type="hidden" name="handoverId" value="${h.shiftHandoverId}"><input type="hidden" name="taskId" value="${t.shiftHandoverTaskId}"><select name="status" class="form-control" onchange="this.form.submit()"><option value="NEW" ${t.status == 'NEW' ? 'selected' : ''}>Mới</option><option value="IN_PROGRESS" ${t.status == 'IN_PROGRESS' ? 'selected' : ''}>Đang xử lý</option><option value="DONE" ${t.status == 'DONE' ? 'selected' : ''}>Đã xử lý</option></select></form></c:when><c:otherwise><span class="badge ${t.statusBadge}">${t.statusLabel}</span></c:otherwise></c:choose></div></c:forEach></article></c:forEach></c:otherwise></c:choose>
<jsp:include page="../layout/footer.jsp" />

{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Cafe: Sync Local Database",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\sync-local-database.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Cafe: Build WAR",
            "type": "process",
            "command": "C:\\apache-maven-3.9.16\\bin\\mvn.cmd",
            "args": [
                "package",
                "-DskipTests"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "JAVA_HOME": "C:\\Program Files\\Java\\jdk-21.0.11"
                }
            },
            "problemMatcher": ["$javac"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Cafe: Start Tomcat (Debug)",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\vscode-tomcat.ps1",
                "-Action",
                "run",
                "-DebugServer"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Cafe: Sync Local Database",
                "Cafe: Build WAR"
            ],
            "dependsOrder": "sequence",
            "isBackground": true,
            "problemMatcher": [
                {
                    "owner": "cafe-tomcat",
                    "pattern": [
                        {
                            "regexp": "^NEVER_MATCH_THIS_LINE$"
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^\\[vscode\\] Starting Tomcat",
                        "endsPattern": "Server startup in"
                    }
                }
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Cafe: Stop Tomcat",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\vscode-tomcat.ps1",
                "-Action",
                "stop"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
